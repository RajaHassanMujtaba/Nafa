# MongoDB Atlas connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/equilibrium?retryWrites=true&w=majority

# JWT secret for auth tokens (use a strong secret in production)
JWT_SECRET=your_jwt_secret_here

# Backend port
PORT=4000

# Local frontend URL (used for CORS during development)
CLIENT_URL=http://localhost:5173
